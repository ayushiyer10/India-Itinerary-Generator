{
  "name": "india-itinerary-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "India AI Itinerary Planner Desktop App",
  "author": "Ayush Iyer",
  "main": "electron/main.cjs",
  "type": "module",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",

    "kill-java": "taskkill /F /IM java.exe >nul 2>&1 || echo Java not running",

    "backend:jar": "cd ../backend && mvn clean package",

    "copy:jar": "if not exist electron\\resources\\backend mkdir electron\\resources\\backend && copy ..\\backend\\target\\itinerary-backend-0.0.1-SNAPSHOT.jar electron\\resources\\backend\\app.jar",

    "dist": "npm run kill-java && npm run build && npm run backend:jar && npm run copy:jar && electron-builder"
  },

  "dependencies": {
    "animejs": "^3.2.2",
    "axios": "^1.7.9",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.30.1"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.8"
  },

  "build": {
    "appId": "com.indiatravel.desktop",
    "productName": "India AI Itinerary Planner",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "electron/resources/backend/app.jar",
        "to": "backend/app.jar"
      }
    ],

    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}